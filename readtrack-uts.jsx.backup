    { id:3, titulo:"Redes de Computadoras", autor:"Tanenbaum", tipo:"PDF", totalPaginas:960, paginasLeidas:0, estado:"PENDIENTE", sesiones:[] },
  ],
  meta: { paginasSemana: 400, paginasEstaSemanah: 248, historial: [
    { semana:"May 12–18, 2026", meta:350, leidas:350 },
